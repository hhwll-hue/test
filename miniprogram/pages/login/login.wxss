.page {
  min-height: 100vh;
  padding: 36rpx 28rpx 48rpx;
  background:
    radial-gradient(circle at top left, rgba(249, 115, 22, 0.22), transparent 34%),
    radial-gradient(circle at bottom right, rgba(34, 197, 94, 0.12), transparent 24%),
    linear-gradient(180deg, #0b1014 0%, #151e25 52%, #0f1418 100%);
}

.hero-card,
.login-card {
  border-radius: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  background: linear-gradient(180deg, rgba(29, 39, 47, 0.96), rgba(18, 24, 30, 0.98));
  box-shadow: 0 22rpx 48rpx rgba(0, 0, 0, 0.26);
}

.hero-card {
  margin-bottom: 26rpx;
  padding: 34rpx 30rpx;
}

.hero-kicker {
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: #fb923c;
}

.hero-title {
  margin-top: 16rpx;
  font-size: 46rpx;
  font-weight: 700;
  color: #f8fafc;
}

.hero-desc {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #cbd5e1;
}

.login-card {
  padding: 30rpx 28rpx 34rpx;
}

.section-title {
  margin-bottom: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #f8fafc;
}

.field-label {
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: #94a3b8;
}

.text-input {
  height: 90rpx;
  padding: 0 24rpx;
  border-radius: 18rpx;
  background: rgba(15, 23, 30, 0.88);
  border: 1rpx solid rgba(251, 146, 60, 0.35);
  color: #f8fafc;
  font-size: 28rpx;
}

.tips {
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #cbd5e1;
}

.error-text {
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #fca5a5;
}

.login-button {
  margin-top: 28rpx;
  height: 88rpx;
  line-height: 88rpx;
  border: none;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #16a34a 0%, #22c55e 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
}

.login-button::after {
  border: none;
}
