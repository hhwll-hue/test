<view class="page">
  <view class="hero-card">
    <view class="hero-kicker">WECHAT PHONE AUTH</view>
    <view class="hero-title">工业风机价格录入</view>
    <view class="hero-desc">使用微信手机号授权登录，系统会按数据库预留手机号自动匹配账号。</view>
  </view>

  <view class="login-card">
    <view class="section-title">登录信息</view>

    <view class="tips">
      请确保当前微信绑定手机号，且该手机号已提前维护到 `app_user.phone`。
    </view>

    <view wx:if="{{error}}" class="error-text">{{error}}</view>

    <button
      class="login-button"
      open-type="getPhoneNumber"
      loading="{{loggingIn}}"
      disabled="{{loggingIn}}"
      bindgetphonenumber="onGetPhoneNumber"
    >
      微信手机号登录
    </button>
  </view>
</view>
