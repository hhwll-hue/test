.page {
  --bg-panel: #1a2229;
  --bg-panel-soft: #232f38;
  --line: rgba(255, 255, 255, 0.08);
  --text-main: #f3f4f6;
  --text-muted: #9ca3af;
  --accent: #f97316;
  --accent-strong: #fb923c;
  --success: #22c55e;
  min-height: 100vh;
  padding: 32rpx 24rpx 56rpx;
  background:
    radial-gradient(circle at top right, rgba(249, 115, 22, 0.24), transparent 30%),
    linear-gradient(180deg, #0f1418 0%, #141c22 48%, #0e1216 100%);
}

.header {
  margin-bottom: 28rpx;
  padding: 28rpx;
  border: 1rpx solid var(--line);
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.02));
  box-shadow: 0 18rpx 40rpx rgba(0, 0, 0, 0.25);
}

.header-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.title {
  font-size: 42rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: var(--text-main);
}

.summary {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: var(--accent-strong);
}

.logout-button {
  margin: 0;
  min-width: 120rpx;
  height: 64rpx;
  line-height: 64rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 999rpx;
  background: rgba(15, 23, 30, 0.42);
  color: var(--text-main);
  font-size: 22rpx;
}

.logout-button::after {
  border: none;
}

.status-card,
.product-card {
  border: 1rpx solid var(--line);
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(33, 42, 50, 0.98), rgba(21, 28, 34, 0.98));
  box-shadow: 0 18rpx 44rpx rgba(0, 0, 0, 0.28);
}

.status-card {
  padding: 28rpx 24rpx;
  color: var(--text-main);
}

.error {
  color: #fca5a5;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.product-card {
  overflow: hidden;
}

.product-image {
  width: 100%;
  height: 320rpx;
  background: #2f3942;
}

.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-muted);
  font-size: 28rpx;
}

.product-body {
  padding: 24rpx 24rpx 12rpx;
}

.field-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.field-label {
  min-width: 120rpx;
  font-size: 24rpx;
  color: var(--text-muted);
  letter-spacing: 1rpx;
}

.field-value,
.price-value {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  line-height: 1.5;
  color: var(--text-main);
  word-break: break-all;
}

.price-row {
  border-bottom: none;
}

.price-value {
  color: var(--accent-strong);
  font-size: 34rpx;
  font-weight: 700;
}

.price-time {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: var(--success);
  text-align: right;
}

.price-editor {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 24rpx 24rpx;
}

.price-input {
  flex: 1;
  height: 84rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  background: var(--bg-panel-soft);
  border: 1rpx solid rgba(249, 115, 22, 0.35);
  color: var(--text-main);
  font-size: 28rpx;
}

.save-button {
  margin: 0;
  min-width: 188rpx;
  height: 84rpx;
  line-height: 84rpx;
  border: none;
  border-radius: 16rpx;
  padding: 0 28rpx;
  background: linear-gradient(135deg, var(--accent) 0%, var(--accent-strong) 100%);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
}

.save-button::after {
  border: none;
}
