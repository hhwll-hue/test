.page {
  padding: 32rpx 24rpx 48rpx;
}

.header {
  margin-bottom: 24rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  color: #111827;
}

.subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.status-card,
.item {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.status-card {
  color: #374151;
}

.error {
  color: #b91c1c;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.fan-type {
  font-size: 30rpx;
  color: #111827;
}
