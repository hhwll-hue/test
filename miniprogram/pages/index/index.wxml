<view class="page">
  <view class="header">
    <view class="title">工业风机价格录入</view>
    <view class="summary" wx:if="{{!loading && !error}}">
      当前共 {{totalProducts}} 个产品
    </view>
  </view>

  <view wx:if="{{loading}}" class="status-card">数据加载中...</view>

  <view wx:elif="{{error}}" class="status-card error">{{error}}</view>

  <view wx:elif="{{products.length === 0}}" class="status-card">数据库中暂无数据</view>

  <view wx:else class="list">
    <view wx:for="{{products}}" wx:for-item="product" wx:for-index="index" wx:key="id" class="product-card">
      <image
        wx:if="{{product.image_url}}"
        class="product-image"
        src="{{product.image_url}}"
        mode="aspectFill"
        show-menu-by-longpress
      />
      <view wx:else class="product-image placeholder">暂无图片</view>

      <view class="product-body">
        <view class="field-row">
          <text class="field-label">产品名称</text>
          <text class="field-value">{{product.product_name || '-'}}</text>
        </view>
        <view class="field-row">
          <text class="field-label">型号</text>
          <text class="field-value">{{product.model || '-'}}</text>
        </view>
        <view class="field-row">
          <text class="field-label">电压</text>
          <text class="field-value">{{product.voltage || '-'}}</text>
        </view>
        <view class="field-row">
          <text class="field-label">功率</text>
          <text class="field-value">{{product.power || '-'}}</text>
        </view>
        <view class="field-row price-row">
          <text class="field-label">当前价格</text>
          <text class="price-value">{{product.purchase_price || '未录入'}}</text>
        </view>
        <view wx:if="{{product.price_time}}" class="price-time">{{product.price_time}}</view>
      </view>

      <view class="price-editor">
        <input
          class="price-input"
          type="digit"
          placeholder="输入采购价格"
          value="{{product.draftPrice}}"
          data-index="{{index}}"
          bindinput="onPriceInput"
        />
        <button
          class="save-button"
          size="mini"
          loading="{{savingProductId === product.id}}"
          disabled="{{savingProductId === product.id}}"
          data-index="{{index}}"
          bindtap="submitPrice"
        >
          保存价格
        </button>
      </view>
    </view>
  </view>
</view>
